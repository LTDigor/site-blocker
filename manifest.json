{
  "manifest_version": 3,
  "name": "URL Image Blocker",
  "version": "1.1",

  "permissions": [
    "storage",
    "webNavigation",
    "tabs"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "src/background/background.js",
    "type": "module"
  },

  "action": {
    "default_popup": "src/popup/popup.html"
  },

  "web_accessible_resources": [
    {
      "resources": [
        "src/blocked/block.html",
        "src/blocked/blocked.js",
        "assets/images/image.jpg"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
