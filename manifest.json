{
  "manifest_version": 3,
  "name": "URL Image Blocker",
  "version": "1.1",

  "permissions": [
    "storage",
    "webNavigation",
    "tabs"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html"
  },

  "web_accessible_resources": [
    {
      "resources": ["block.html", "image.jpg"],
      "matches": ["<all_urls>"]
    }
  ]
}